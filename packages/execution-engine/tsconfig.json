{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "../",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node"],
    "paths": {
      "@polymarket-btc-5m-agentic-bot/*": ["../*/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../domain/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
