BOT_MIN_LIVE_TRADES_FOR_SCALED_LIVE=20
BOT_MAX_ALLOWED_REALIZED_EXPECTED_EDGE_GAP_BPS=50
BOT_MAX_ALLOWED_RECONCILIATION_DEFECT_RATE=0.10
BOT_ENABLE_SHADOW_DECISION_LOGGING=true
BOT_REQUIRE_PRODUCTION_READINESS_PASS=true
BOT_MAX_BTC_SNAPSHOT_AGE_MS=15000
BOT_MAX_SIGNAL_AGE_MS=15000
BOT_MAX_ORDERBOOK_AGE_MS=8000
